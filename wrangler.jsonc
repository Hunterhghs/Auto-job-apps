{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "auto-job-apps",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],

  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },

  // Scout-and-apply pipeline: fires every 10 min (~144 intervals/day).
  // Daily cap (default 15) throttles actual applications — most intervals
  // just check and skip, giving natural 10-30 min spacing between applies.
  "triggers": {
    "crons": ["*/10 * * * *"]
  },

  // Dashboard static site. API routes are handled by the Worker first.
  "assets": {
    "directory": "public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },

  "browser": { "binding": "BROWSER" },
  "ai": { "binding": "AI" },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "auto-job-apps",
      "database_id": "a6964841-b1c5-49ec-9c1d-0666f8ba9c69"
    }
  ],

  "kv_namespaces": [
    {
      "binding": "CONFIG",
      "id": "e90a66d8e8694ee0b90b31a08cb71728"
    }
  ],

  "r2_buckets": [
    {
      "binding": "FILES",
      "bucket_name": "auto-job-apps"
    }
  ],

  // Email Routing: receives forwarded emails (verification codes)
  // to apply@hheuristics.com → Worker extracts codes → stores in KV
  "workers_email": true

  // Secrets (set with `wrangler secret put <NAME>`):
  //   DASHBOARD_PASSCODE - passcode for the dashboard login
  //   DEEPSEEK_API_KEY   - DeepSeek API key for AI answers & cover letters
}
